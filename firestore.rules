
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas globales para asegurar acceso autenticado en todas las colecciones principales
    // Nota: Se agregan comentarios para forzar el despliegue de reglas mediante el watcher.
    
    match /stations/{stationId} {
      allow read, write: if request.auth != null;
    }

    match /levantamientos/{surveyId} {
      allow read, write: if request.auth != null;
    }
    
    match /reports/{reportId} {
      allow read, write: if request.auth != null;
    }
    
    match /samples/{sampleId} {
      allow read, write: if request.auth != null;
    }
    
    match /custom_templates/{templateId} {
      allow read, write: if request.auth != null;
    }
    
    match /presence/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}
