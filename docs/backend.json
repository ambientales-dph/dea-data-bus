
{
  "entities": {
    "Station": {
      "title": "Station",
      "description": "Una ubicación fija de monitoreo ambiental (punto de muestreo).",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Denominación de la estación." },
        "latitude": { "type": "number", "description": "Latitud geográfica." },
        "longitude": { "type": "number", "description": "Logitud geográfica." },
        "basinCode": { "type": "string", "description": "Código de la cuenca detectado." },
        "userId": { "type": "string", "description": "ID del usuario que creó la estación." },
        "userEmail": { "type": "string", "description": "Email del usuario creador." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Fecha de creación." }
      },
      "required": ["name", "latitude", "longitude"]
    },
    "Report": {
      "title": "Report",
      "description": "Un reporte de monitoreo que agrupa múltiples mediciones.",
      "type": "object",
      "properties": {
        "oid": { "type": "string", "description": "Identificador único técnico del reporte (RM + Cuenca + Secuencial)." },
        "stationId": { "type": "string", "description": "ID de la estación asociada." },
        "trelloCardName": { "type": "string", "description": "Nombre de la tarjeta de Trello (Proyecto) asociada." },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdByEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "editors": { "type": "array", "items": { "type": "string" }, "description": "Emails de los técnicos que aportaron datos." }
      },
      "required": ["stationId", "createdAt", "createdByEmail", "oid"]
    },
    "Sample": {
      "title": "Sample",
      "description": "Medición de un parámetro específico en una estación.",
      "type": "object",
      "properties": {
        "reportId": { "type": "string", "description": "Referencia al reporte de origen." },
        "formId": { "type": "string", "description": "ID único de la instancia de la planilla dentro del reporte." },
        "stationId": { "type": "string", "description": "Referencia a la estación de origen." },
        "medium": { "type": "string", "enum": ["agua_superficial", "agua_subterranea", "suelo", "sedimentos"], "description": "Medio ambiental (Matriz)." },
        "parameterType": { "type": "string", "description": "Categoría del parámetro (Fisicoquímico, etc)." },
        "analyte": { "type": "string", "description": "Nombre del analito (pH, Pb, etc)." },
        "value": { "type": "string", "description": "Valor numérico o resultado de la medición." },
        "timestamp": { "type": "string", "format": "date-time", "description": "Momento de la toma de muestra." },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" }
      },
      "required": ["reportId", "formId", "stationId", "medium", "parameterType", "analyte", "value"]
    },
    "CustomTemplate": {
      "title": "CustomTemplate",
      "description": "Plantilla de parámetros personalizada creada por un usuario.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "medium": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "parameters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "nombre": { "type": "string" },
              "categoria": { "type": "string" },
              "unidades": { "type": "string" },
              "nivelGuia": { "type": "string" },
              "ley": { "type": "string" }
            }
          }
        }
      },
      "required": ["name", "parameters"]
    },
    "Presence": {
      "title": "Presence",
      "description": "Ubicación actual que un usuario está visualizando o editando.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "name": { "type": "string", "description": "Nombre del punto o estación seleccionada." },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "latitude", "longitude"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/stations/{stationId}": {
      "schema": "#/backend/entities/Station",
      "description": "Colección de puntos de muestreo fijos."
    },
    "/reports/{reportId}": {
      "schema": "#/backend/entities/Report",
      "description": "Colección de reportes de monitoreo."
    },
    "/samples/{sampleId}": {
      "schema": "#/backend/entities/Sample",
      "description": "Colección de resultados de laboratorio y mediciones de campo."
    },
    "/custom_templates/{templateId}": {
      "schema": "#/backend/entities/CustomTemplate",
      "description": "Plantillas personalizadas creadas por técnicos."
    },
    "/presence/{userId}": {
      "schema": "#/backend/entities/Presence",
      "description": "Estado de presencia en tiempo real de los usuarios activos."
    }
  }
}
